function! s:asyncomplete_force_refresh_after(char) abort
  if &paste || !exists('g:asyncomplete_loaded')
    return a:char
  endif
  return a:char . (pumvisible() ? "\<C-e>" : '') . "\<C-r>=asyncomplete#_force_refresh()\<CR>"
endfunction

function! s:asyncomplete_force_refresh_after_if_prev(char, prev) abort
  if col('.') < 2 || getline('.')[col('.') - 2] !=# a:prev
    return a:char
  endif
  return s:asyncomplete_force_refresh_after(a:char)
endfunction


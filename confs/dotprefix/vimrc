function! s:goto_quickfix_file_window(is_loclist) abort
  if a:is_loclist
    let l:filewinid = get(getloclist(0, {'filewinid': 0}), 'filewinid', 0)
    if l:filewinid && win_gotoid(l:filewinid)
      return 1
    endif
  endif

  let l:prev_winid = win_getid(winnr('#'))
  if l:prev_winid && win_gotoid(l:prev_winid) && &buftype !=# 'quickfix'
    return 1
  endif

  for l:wininfo in getwininfo()
    if get(l:wininfo, 'tabnr', 0) == tabpagenr()
          \ && !get(l:wininfo, 'quickfix', 0)
          \ && getbufvar(l:wininfo.bufnr, '&buftype') ==# ''
      return win_gotoid(l:wininfo.winid)
    endif
  endfor

  return 0
endfunction

function! s:open_quickfix_item_in_vsplit(item) abort
  let l:lnum = max([get(a:item, 'lnum', 1), 1])
  let l:col = max([get(a:item, 'col', 1), 1])
  let l:bufnr = get(a:item, 'bufnr', 0)

  if l:bufnr > 0 && bufexists(l:bufnr)
    execute 'rightbelow vertical sbuffer ' . l:bufnr
  else
    let l:filename = get(a:item, 'filename', '')
    if empty(l:filename)
      echohl WarningMsg
      echom 'Quickfix item has no file to open'
      echohl None
      return
    endif
    execute 'rightbelow vertical split ' . fnameescape(l:filename)
  endif

  call cursor(l:lnum, l:col)
  normal! zvzz
endfunction

function! s:quickfix_open_vsplit() abort
  let l:qf_winid = win_getid()
  let l:wininfo = get(getwininfo(l:qf_winid), 0, {})
  if empty(l:wininfo) || !get(l:wininfo, 'quickfix', 0)
    return
  endif

  let l:is_loclist = get(l:wininfo, 'loclist', 0)
  let l:items = l:is_loclist ? getloclist(0) : getqflist()
  let l:idx = line('.')
  if l:idx < 1 || l:idx > len(l:items)
    echohl WarningMsg
    echom 'No quickfix item under cursor'
    echohl None
    return
  endif

  let l:item = l:items[l:idx - 1]
  if !get(l:item, 'valid', 1)
    echohl WarningMsg
    echom 'Quickfix item under cursor is not valid'
    echohl None
    return
  endif

  if !s:goto_quickfix_file_window(l:is_loclist)
    topleft new
  endif
  call s:open_quickfix_item_in_vsplit(l:item)
endfunction

augroup premium_quickfix
